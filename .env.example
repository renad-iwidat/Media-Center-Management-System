# Database Configuration
DATABASE_URL=

# Server Configuration
PORT=3000
NODE_ENV=development
AI_CLASSIFIER_URL=http://your-ai-classifier-base-url:8080
# Articles Configuration
ARTICLES_PER_SOURCE=20

# Scheduler Configuration
