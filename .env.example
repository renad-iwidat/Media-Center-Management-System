# ===== Database Configuration =====
DATABASE_URL=postgresql://username:password@host:port/database

# ===== Server Configuration =====
PORT=7845
NODE_ENV=production

# ===== Docker Ports (اختياري - افتراضياً 7845 و 7846) =====
